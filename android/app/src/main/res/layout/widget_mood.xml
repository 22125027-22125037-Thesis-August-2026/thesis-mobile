<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="14dp"
    android:background="@drawable/widget_bg_default">

    <ImageView
        android:id="@+id/widget_mood_icon"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_mood_neutral"
        android:src="@drawable/ic_mood_neutral" />

    <TextView
        android:id="@+id/widget_mood_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true"
        android:ellipsize="end"
        android:textColor="@color/widget_text_primary" />

    <TextView
        android:id="@+id/widget_streak_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:singleLine="true"
        android:textColor="@color/widget_text_muted" />

    <TextView
        android:id="@+id/widget_motivational_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/widget_text_secondary" />

</LinearLayout>
